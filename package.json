    "@fastify/static": "^6.12.0",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.10",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10"
  }
