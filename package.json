{
  "name": "fastify-chat",
  "version": "1.0.0",
  "description": "Instant messaging backend with Fastify and WebSocket",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js --port 3000 --jwt-secret your-secret-key --upload-dir uploads/"
  },
  "dependencies": {
    "fastify": "^4.26.0",
